using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.IO;

namespace ConsoleApp1
{
    internal class Auto
    {
        public int Sorszam { get; set; }
        public string Marka { get; set; }
        public string Modell { get; set; }
        public int GyartasiEv { get; set; }
        public string Szin { get; set; }
        public int Eladott { get; set; }
        public int AtlagosAr { get; set; }

        public Auto(string sor) 
        {
            string[] sor2 = sor.Split(';');
            

            Sorszam = Convert.ToInt32(sor2[0]);
            Marka = sor2[1];
            Modell = sor2[2];
            GyartasiEv = Convert.ToInt32(sor2[3]);
            Szin = sor2[4];
            Eladott = Convert.ToInt32(sor2[5]);
            AtlagosAr = Convert.ToInt32(sor2[6]);
        }

        public static List<Auto> Beolvasas(string fajlnev)
        {
            List<Auto> autok = new List<Auto>();
            string[] sorok = File.ReadAllLines(fajlnev);
            for (int i = 1; i < sorok.Length; i++)
            {
                if (!string.IsNullOrWhiteSpace(sorok[i]))
                {
                    autok.Add(new Auto(sorok[i]));
                }
            }
            return autok;
        }
    }


    internal class Program
    {
        static List<Auto> autok = new List<Auto>();

        static void Main(string[] args)
        {
            Feladat4();
            Feladat5();
            Feladat6();
            Feladat7();
            Feladat8();
            
            Console.ReadKey();
        }

        static void Feladat4()
        {
            autok = Auto.Beolvasas("autok.csv");
        }

        static void Feladat5()
        {
            Console.WriteLine("5.feladat: {0} autó található a listában.", autok.Count);
        }

        static void Feladat6()
        {
            int osszeg = 0;

            for (int i = 0; i < autok.Count; i++)
            {
                osszeg += autok[i].Eladott;
            }

            double atlag = (double)osszeg / autok.Count;

            Console.WriteLine("6.feladat: Az autók esetében az átlagosan eladott darabszám {0:0.0}", atlag);
        }

        static void Feladat7()
        {
            Console.WriteLine("7.feladat: Az elmúlt 5 évben gyártott autók:");

            int alsohatar = 2020;

            for (int i = 0; i < autok.Count; i++)
            {
                if (autok[i].GyartasiEv >= alsohatar)
                {
                    Console.WriteLine("\t- " + autok[i].Marka + " " + autok[i].Modell + ": " + autok[i].GyartasiEv);
                }
            }
        }

        static void Feladat8()
        {
            Console.WriteLine("8. feladat: Legsikeresebb márkák listája az eladott darabszám alapján:");

            // 1. Különböző márkák összegyűjtése
            List<string> markak = new List<string>();

            for (int i = 0; i < autok.Count; i++)
            {
                string marka = autok[i].Marka;

                if (!markak.Contains(marka))
                {
                    markak.Add(marka);
                }
            }

            // 2. Minden márkához összesítjük az eladásokat
            List<string> eredmenyMarka = new List<string>();
            List<int> eredmenyEladas = new List<int>();

            for (int i = 0; i < markak.Count; i++)
            {
                string aktualisMarka = markak[i];
                int darab = 0;

                // végigmegyünk az összes autón és összeadjuk amelyik ehhez a márkához tartozik
                for (int j = 0; j < autok.Count; j++)
                {
                    if (autok[j].Marka == aktualisMarka)
                    {
                        darab += autok[j].Eladott;
                    }
                }

                eredmenyMarka.Add(aktualisMarka);
                eredmenyEladas.Add(darab);
            }

            // 3. Rendezés buborékrendezés-szerű (kezdő módon)
            for (int i = 0; i < eredmenyEladas.Count - 1; i++)
            {
                for (int j = i + 1; j < eredmenyEladas.Count; j++)
                {
                    if (eredmenyEladas[j] > eredmenyEladas[i])
                    {
                        int temp = eredmenyEladas[i];
                        eredmenyEladas[i] = eredmenyEladas[j];
                        eredmenyEladas[j] = temp;

                        string temps = eredmenyMarka[i];
                        eredmenyMarka[i] = eredmenyMarka[j];
                        eredmenyMarka[j] = temps;
                    }
                }
            }

            // 4. Kiírás
            for (int i = 0; i < eredmenyMarka.Count; i++)
            {
                Console.WriteLine("\t- " + eredmenyMarka[i] + ": " + eredmenyEladas[i] + " darab");
            }
        }



    }
}



